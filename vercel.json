{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.xiaowei.dev/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://api.xiaowei.dev/admin/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://api.xiaowei.dev/static/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.xiaowei.dev/media/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
